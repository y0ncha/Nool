# Root .gitignore — generic, technology-agnostic
# Place only global ignores here (env, logs, editor, OS, temp files)
# Each component/app should have its own .gitignore for tech-specific ignores

# Environment files
.env
.env.*.local
*.local

# Logs
logs
*.log

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS system files
Thumbs.db
ehthumbs.db

# Temporary files
*.tmp
*.temp